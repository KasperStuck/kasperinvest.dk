---
import { Font } from "astro:assets";
import "@/styles/globals.css";

interface Props {
	title?: string;
	description?: string;
}

const { title = "KasperInvest", description } = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "https://kasperinvest.dk").href;
---

<html lang="da" class="scroll-pt-16 font-sans antialiased text-gray-950 dark:bg-gray-950 dark:text-white">
	<head>
		<meta charset="utf-8" />
		<Font cssVariable="--font-inter" preload />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="google-site-verification" content="CBj3TEDfutmUBZt1pTjvitR7T2R_1q8Rp6ToPE-Cy1Q" />
		{description && <meta name="description" content={description} />}
		<link rel="canonical" href={canonicalUrl} />
		<title>{title}</title>
		<slot name="head" />
		<script is:inline src="/theme-init.js"></script>
	</head>
	<body>
		<div class="isolate">
			<slot />
		</div>
	</body>
</html>
