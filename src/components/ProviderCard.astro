---
import type { Provider } from "@/data/savings";
import ChevronRightIcon from "@/icons/ChevronRightIcon.astro";

interface Props {
	provider: Provider;
	priceLabel?: string;
}

const { provider, priceLabel } = Astro.props;
---

<div class="flex flex-col gap-6 rounded-2xl border border-gray-950/10 bg-white p-6 sm:flex-row sm:items-center dark:border-white/10 dark:bg-gray-950">
	<div class="flex w-full items-center gap-3 sm:max-w-[160px]">
		{provider.logoUrl && (
			<img src={provider.logoUrl} alt="" width={32} height={32} class="size-8 shrink-0 rounded" loading="lazy" />
		)}
		<span class="text-xl font-bold tracking-tight text-gray-950 dark:text-white">
			{provider.name}
		</span>
	</div>

	<div class="flex-1">
		{provider.tag && (
			<p class="text-sm font-medium text-amber-600 dark:text-amber-400">{provider.tag}</p>
		)}
		<p class="text-lg font-medium text-gray-950 dark:text-white">{provider.description}</p>
		{provider.specs && (
			<dl class="mt-3 flex flex-wrap gap-x-6 gap-y-2">
				{provider.specs.map((s) => (
					<div>
						<dt class="text-xs font-semibold text-gray-950 dark:text-white">{s.label}</dt>
						<dd class="text-sm text-gray-600 dark:text-gray-400">{s.value}</dd>
					</div>
				))}
			</dl>
		)}
	</div>

	<div class="flex flex-col items-start gap-3 sm:items-end">
		<div class="text-right">
			{priceLabel && <p class="text-xs text-gray-600 dark:text-gray-400">{priceLabel}</p>}
			<p class="text-2xl font-bold tracking-tight text-gray-950 dark:text-white">{provider.price}</p>
			{provider.priceSub && (
				<p class="text-sm text-gray-600 dark:text-gray-400">{provider.priceSub}</p>
			)}
		</div>
		<a
			href={provider.url}
			target="_blank"
			rel="nofollow noopener sponsored"
			class="inline-flex items-center gap-1 rounded-full bg-emerald-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-700"
		>
			Gå til udbyder
			<ChevronRightIcon />
		</a>
	</div>
</div>
