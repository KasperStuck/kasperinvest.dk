---
import { getImage } from "astro:assets";
import { banners as rawBanners } from "@/data/banners";

interface Props {
	empty?: boolean;
	emptyMessage?: string;
}

const { empty = false, emptyMessage = "Denne artikel er under udarbejdelse." } = Astro.props;

const banners = await Promise.all(
	rawBanners.map(async ({ image, ...rest }) => {
		const { src, attributes } = await getImage({ src: image, format: "webp" });
		return { src, width: attributes.width as number, height: attributes.height as number, ...rest };
	}),
);
---

{empty ? (
	<div id="content" class="prose prose-sm dark:prose-invert">
		<div class="flex flex-col items-center justify-center py-20 text-center">
			<p class="text-lg font-medium text-gray-950 dark:text-white">Kommer snart</p>
			<p class="mt-2 text-sm text-gray-600">{emptyMessage}</p>
		</div>
	</div>
) : (
	<div>
		<div id="content" class="prose prose-sm dark:prose-invert">
			<slot />
		</div>

		<script define:vars={{ banners }}>
			const content = document.getElementById("content");
			const pageText = (document.title + " " + content.textContent).toLowerCase();

			const matched = banners.filter(
				(b) =>
					b.keywords.length > 0 &&
					b.keywords.some((kw) => pageText.includes(kw)) &&
					!b.exclude.some((kw) => pageText.includes(kw)),
			);
			const pool = matched.length > 0 ? matched : banners;

			function createBanner() {
				const b = pool[Math.floor(Math.random() * pool.length)];
				const link = document.createElement("a");
				link.href = b.href;
				link.target = "_blank";
				link.rel = "noopener";
				link.className = "not-prose my-8 block overflow-hidden";

				const img = document.createElement("img");
				Object.assign(img, { src: b.src, alt: b.alt, width: b.width, height: b.height, loading: "lazy" });
				img.className = "w-full";

				link.appendChild(img);
				return link;
			}

			content.prepend(createBanner());
			content.append(createBanner());

			const headings = content.querySelectorAll(":scope > h2");
			for (let i = 2; i < headings.length; i += 3) {
				let next = headings[i].nextElementSibling;
				while (next && next.tagName !== "H2") next = next.nextElementSibling;
				content.insertBefore(createBanner(), next);
			}
		</script>
	</div>
)}
