---
import CenteredLayout from "@/layouts/CenteredLayout.astro";
---

<CenteredLayout title="Side ikke fundet - KasperInvest">
	<div class="flex flex-col items-center justify-center py-32 text-center">
		<p class="text-sm font-semibold text-gray-500">404</p>
		<h1 class="mt-4 text-4xl font-semibold tracking-tight text-gray-950 sm:text-5xl dark:text-white">
			Side ikke fundet
		</h1>
		<p class="mt-6 text-base/7 text-gray-600 dark:text-gray-400">
			Siden du leder efter findes ikke eller er blevet flyttet.
		</p>
		<div class="mt-10">
			<a
				href="/"
				class="rounded-md bg-gray-950 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-gray-800 dark:bg-white dark:text-gray-950 dark:hover:bg-gray-200"
			>
				Gå til forsiden
			</a>
		</div>
	</div>
</CenteredLayout>
