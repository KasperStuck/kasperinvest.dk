---
import { Image } from "astro:assets";
import norminvestPar from "@/assets/partners/norminvest-par.png";
import norminvestKvinde from "@/assets/partners/norminvest-kvinde.png";
import nordnetLivrenteMand from "@/assets/partners/nordnet-livrente-mand.png";
import nordnetLivrenteKvinde from "@/assets/partners/nordnet-livrente-kvinde.png";
import nordnetMindreaarig from "@/assets/partners/nordnet-mindreaarig.png";

interface Props {
	pageText?: string;
}

const { pageText = "" } = Astro.props;
const text = pageText.toLowerCase();

const banners = [
	{
		src: norminvestPar,
		alt: "Norm Invest - Par der investerer sammen",
		href: "https://at.norminvest.com/t/t?a=1873806307&as=2056026217&t=2&tk=1",
		keywords: ["investering", "aktier", "fond", "etf", "opsparing"],
	},
	{
		src: norminvestKvinde,
		alt: "Norm Invest - Start din investering",
		href: "https://at.norminvest.com/t/t?a=1873806302&as=2056026217&t=2&tk=1",
		keywords: ["investering", "aktier", "fond", "etf", "opsparing"],
	},
	{
		src: nordnetLivrenteMand,
		alt: "Nordnet - Livsvarig pension, flyt din livrente",
		href: "https://go.adt212.net/t/t?a=1930764499&as=2056026217&t=2&tk=1",
		keywords: ["pension", "livrente", "ratepension", "aldersopsparing"],
	},
	{
		src: nordnetLivrenteKvinde,
		alt: "Nordnet - Invester selv din pension, flyt din livrente",
		href: "https://go.adt212.net/t/t?a=1930763698&as=2056026217&t=2&tk=1",
		keywords: ["pension", "livrente", "ratepension", "aldersopsparing"],
	},
	{
		src: nordnetMindreaarig,
		alt: "Nordnet - Opret en konto for mindreårige",
		href: "https://go.adt212.net/t/t?a=1886842299&as=2056026217&t=2&tk=1",
		keywords: ["børn", "mindreårig", "børneopsparing", "barn"],
	},
];

// Filter by keywords if pageText is provided, otherwise use all
const matched = text
	? banners.filter((b) => b.keywords.some((kw) => text.includes(kw)))
	: banners;
const pool = matched.length > 0 ? matched : banners;
const banner = pool[Math.floor(Math.random() * pool.length)];
---

<a
	href={banner.href}
	target="_blank"
	rel="noopener"
	class="not-prose my-8 block overflow-hidden"
>
	<Image
		src={banner.src}
		alt={banner.alt}
		width={930}
		height={600}
		class="w-full"
		loading="lazy"
	/>
</a>
