---
import type { Provider } from "@/data/savings";
import ChevronRightIcon from "@/icons/ChevronRightIcon.astro";

interface Props {
	provider: Provider;
}

const { provider } = Astro.props;
---

<div class="flex flex-col gap-5 rounded-2xl border border-gray-950/10 bg-white p-6 sm:flex-row sm:items-center dark:border-white/10 dark:bg-gray-950" data-provider>
	<div class="flex-1">
		{provider.logoUrl ? (
			<>
				<span class="inline-block dark:rounded-md dark:bg-white dark:px-2 dark:py-1">
					<img
						src={provider.logoUrl}
						alt={provider.name}
						class="max-h-10"
						loading="lazy"
						data-provider-logo
						onload="this.parentElement.parentElement.querySelector('[data-provider-name]').hidden=true"
						onerror="this.parentElement.hidden=true;this.parentElement.parentElement.querySelector('[data-provider-name]').hidden=false"
					/>
				</span>
				<p class="text-lg font-semibold text-gray-950 dark:text-white" data-provider-name hidden>{provider.name}</p>
			</>
		) : (
			<p class="text-lg font-semibold text-gray-950 dark:text-white">{provider.name}</p>
		)}
	</div>
	<a
		href={provider.url}
		target="_blank"
		rel="nofollow noopener sponsored"
		class="inline-flex shrink-0 items-center gap-1 rounded-full bg-emerald-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-700"
	>
		Besøg udbyder
		<ChevronRightIcon />
	</a>
</div>
