---
import SectionLayout from "@/layouts/SectionLayout.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import ChevronRightIcon from "@/icons/ChevronRightIcon.astro";
import ProseWithAds from "@/components/ProseWithAds.astro";
import { getPensionTypes, getPensionType, getPensionContent } from "@/data/pension";

export function getStaticPaths() {
	return getPensionTypes().map((p) => ({
		params: { slug: p.id },
	}));
}

const { slug } = Astro.params;
const pension = getPensionType(slug!);

if (!pension) {
	return new Response(null, { status: 404, statusText: "Not Found" });
}

const sidebarItems = getPensionTypes().map((p) => ({
	id: p.id,
	title: p.title,
	href: `/pension/${p.id}`,
}));

let Content: any = null;
try {
	Content = await getPensionContent(slug!);
} catch {
	// MDX file doesn't exist yet
}

const breadcrumbItems = [
	{ label: "KasperInvest", href: "/" },
	{ label: "Pension", href: `/pension/${getPensionTypes()[0].id}`, class: "max-md:hidden" },
	{ label: pension.title },
];
---

<SectionLayout
	title={`${pension.title} - Pension - KasperInvest`}
	description={pension.description}
	breadcrumbItems={breadcrumbItems}
	sectionTitle="Pension"
	sidebarItems={sidebarItems}
>
	<div class="mx-auto max-w-7xl">
		<div class="mx-auto flex max-w-2xl gap-x-10 py-10 sm:py-14 lg:max-w-5xl">
			<div class="w-full flex-1">
				{Content ? (
					<ProseWithAds>
						<Content />
					</ProseWithAds>
				) : (
					<div id="content" class="prose prose-sm dark:prose-invert">
						<div class="flex flex-col items-center justify-center py-20 text-center">
							<p class="text-lg font-medium text-gray-950 dark:text-white">Kommer snart</p>
							<p class="mt-2 text-sm text-gray-500">Denne artikel er under udarbejdelse.</p>
						</div>
					</div>
				)}
				<div class="mt-16 border-t border-gray-200 pt-8 dark:border-white/10">
					{pension.next ? (
						<div class="flow-root">
							<a
								href={`/pension/${pension.next.id}`}
								class="-mx-3 -my-2 block rounded-xl px-3 py-2 hover:bg-gray-950/4 dark:hover:bg-white/5"
							>
								<p class="flex items-center gap-3 text-sm/7 text-gray-500">
									Næste
									<ChevronRightIcon />
								</p>
								<p class="mt-3 text-base/7 font-medium text-gray-950 dark:text-white">
									{pension.next.title}
								</p>
								<p class="text-sm/7 text-gray-700 dark:text-gray-400">
									{pension.next.description}
								</p>
							</a>
						</div>
					) : (
						<div class="flow-root">
							<a
								href="/"
								class="-mx-3 -my-2 block rounded-xl px-3 py-2 hover:bg-gray-950/4 dark:hover:bg-white/5"
							>
								<p class="flex items-center gap-3 text-sm/7 text-gray-500">
									Tilbage
									<ChevronRightIcon />
								</p>
								<p class="mt-3 text-base/7 font-medium text-gray-950 dark:text-white">
									Kursusoversigt
								</p>
								<p class="text-sm/7 text-gray-700 dark:text-gray-400">
									Gå tilbage til investeringskurset.
								</p>
							</a>
						</div>
					)}
				</div>
			</div>
			<div class="hidden w-66 lg:block">
				<TableOfContents contentId="content" />
			</div>
		</div>
	</div>
</SectionLayout>
