---
import CenteredLayout from "@/layouts/CenteredLayout.astro";
import { getModules } from "@/data/lessons";
import { getElections } from "@/data/elections";

const modules = getModules();
const elections = getElections();
---

<CenteredLayout title="Sitemap - KasperInvest" description="Komplet oversigt over alle sider på KasperInvest.">
	<nav slot="breadcrumbs" aria-label="Breadcrumb" class="flex items-center gap-x-2 text-sm/6">
		<a href="/" class="min-w-0 shrink-0 text-gray-950 dark:text-white">KasperInvest</a>
		<span class="text-gray-950/25 dark:text-white/25">/</span>
		<span class="min-w-0 truncate text-gray-600 dark:text-gray-400">Sitemap</span>
	</nav>

	<h1 class="mt-10 text-3xl/10 font-normal tracking-tight text-gray-950 sm:mt-14 dark:text-white">
		Sitemap
	</h1>
	<p class="mt-6 max-w-xl text-base/7 text-gray-600 dark:text-gray-400">
		Komplet oversigt over alle sider på KasperInvest.
	</p>

	<div class="mt-16 space-y-16">
		<section class="grid grid-cols-4 border-t border-gray-950/10 dark:border-white/10">
			<div class="col-span-full sm:col-span-1">
				<div class="-mt-px inline-flex border-t border-gray-950 pt-px dark:border-white">
					<div class="pt-4 text-sm/7 font-semibold text-gray-950 sm:pt-10 dark:text-white">
						<h2>Sider</h2>
					</div>
				</div>
			</div>
			<div class="col-span-full pt-6 sm:col-span-3 sm:pt-10">
				<ul class="space-y-3 text-sm/7">
					<li><a href="/" class="text-gray-950 underline decoration-gray-950/25 hover:decoration-gray-950 dark:text-white dark:decoration-white/25 dark:hover:decoration-white">Kursusoversigt</a></li>
					<li><a href="/resources" class="text-gray-950 underline decoration-gray-950/25 hover:decoration-gray-950 dark:text-white dark:decoration-white/25 dark:hover:decoration-white">Resources</a></li>
					<li><a href="/youtube" class="text-gray-950 underline decoration-gray-950/25 hover:decoration-gray-950 dark:text-white dark:decoration-white/25 dark:hover:decoration-white">YouTube</a></li>
				</ul>
			</div>
		</section>

		{modules.map((mod, i) => (
			<section class="grid grid-cols-4 border-t border-gray-950/10 dark:border-white/10">
				<div class="col-span-full sm:col-span-1">
					<div class="-mt-px inline-flex border-t border-gray-950 pt-px dark:border-white">
						<div class="pt-4 text-sm/7 font-semibold text-gray-950 sm:pt-10 dark:text-white">
							<h2>Modul {i + 1}</h2>
						</div>
					</div>
				</div>
				<div class="col-span-full pt-6 sm:col-span-3 sm:pt-10">
					<p class="text-sm/7 font-medium text-gray-950 dark:text-white">{mod.title}</p>
					<ul class="mt-4 space-y-3 text-sm/7">
						{mod.lessons.map((lesson) => (
							<li>
								<a href={`/${lesson.id}`} class="text-gray-700 underline decoration-gray-950/25 hover:text-gray-950 hover:decoration-gray-950 dark:text-gray-400 dark:decoration-white/25 dark:hover:text-white dark:hover:decoration-white">
									{lesson.title}
								</a>
							</li>
						))}
					</ul>
				</div>
			</section>
		))}

		{elections.map((election) => (
			<section class="grid grid-cols-4 border-t border-gray-950/10 dark:border-white/10">
				<div class="col-span-full sm:col-span-1">
					<div class="-mt-px inline-flex border-t border-gray-950 pt-px dark:border-white">
						<div class="pt-4 text-sm/7 font-semibold text-gray-950 sm:pt-10 dark:text-white">
							<h2>{election.title}</h2>
						</div>
					</div>
				</div>
				<div class="col-span-full pt-6 sm:col-span-3 sm:pt-10">
					<p class="text-sm/7 text-gray-600 dark:text-gray-400">{election.description}</p>
					<ul class="mt-4 space-y-3 text-sm/7">
						<li>
							<a href={`/folketingsvalg/${election.year}`} class="text-gray-700 underline decoration-gray-950/25 hover:text-gray-950 hover:decoration-gray-950 dark:text-gray-400 dark:decoration-white/25 dark:hover:text-white dark:hover:decoration-white">
								Oversigt
							</a>
						</li>
						{election.articles.map((article) => (
							<li>
								<a href={`/folketingsvalg/${election.year}/${article.id}`} class="text-gray-700 underline decoration-gray-950/25 hover:text-gray-950 hover:decoration-gray-950 dark:text-gray-400 dark:decoration-white/25 dark:hover:text-white dark:hover:decoration-white">
									{article.title}
								</a>
							</li>
						))}
					</ul>
				</div>
			</section>
		))}
	</div>
</CenteredLayout>
