---
import CloseIcon from "@/icons/CloseIcon.astro";
import MenuIcon from "@/icons/MenuIcon.astro";
import MoonIcon from "@/icons/MoonIcon.astro";
import SunIcon from "@/icons/SunIcon.astro";

const links = [
	{ href: "/", label: "Kursus" },
	{ href: "/pension", label: "Pension" },
	{ href: "/platforme", label: "Platforme" },
	{ href: "/ordbog", label: "Ordbog" },
	{ href: "/spar-penge", label: "Spar penge" },
	{ href: "/youtube", label: "YouTube" },
];

const mobileLink =
	"block rounded-md px-4 py-1.5 text-lg/7 font-medium tracking-tight text-gray-950 hover:bg-gray-950/5 dark:text-white dark:hover:bg-white/5";
---

<div class="sticky top-0 z-40 flex items-center justify-between gap-x-8 bg-white/90 px-4 py-4 backdrop-blur-sm sm:px-6 dark:bg-gray-950/90">
  <slot />

  <nav class="flex items-center">
    <!-- Mobile: theme toggle + menu button -->
    <div class="flex items-center gap-4 lg:hidden">
      <button
        type="button"
        class="relative cursor-pointer *:relative before:absolute before:top-1/2 before:left-1/2 before:size-8 before:-translate-1/2 before:rounded-md hover:before:bg-gray-950/5 focus:outline-hidden dark:hover:before:bg-white/5"
        data-toggle-theme
        aria-label="Skift tema"
      >
        <SunIcon class="hidden text-gray-950 dark:block dark:text-white" />
        <MoonIcon class="block text-gray-950 dark:hidden dark:text-white" />
      </button>
      <button
        type="button"
        class="flex cursor-pointer items-center gap-1.5 text-sm/6 font-medium text-gray-950 hover:text-gray-600 focus:outline-hidden dark:text-white dark:hover:text-gray-300"
        data-open-site-nav
      >
        <span>Menu</span>
        <MenuIcon />
      </button>
    </div>

    <!-- Mobile nav dialog -->
    <div class="fixed inset-0 z-50 hidden lg:hidden" id="site-mobile-nav">
      <div class="fixed inset-0 bg-gray-950/25" data-close-site-nav></div>
      <div class="fixed inset-0 flex justify-end pl-11">
        <div class="min-h-screen w-full max-w-2xs overflow-y-auto bg-white px-4 py-5 shadow-lg ring ring-gray-950/10 sm:px-6 dark:bg-gray-950 dark:ring-white/10">
          <div class="flex justify-end">
            <button
              type="button"
              class="relative cursor-pointer *:relative before:absolute before:top-1/2 before:left-1/2 before:size-8 before:-translate-1/2 before:rounded-md before:bg-white/75 before:backdrop-blur-sm hover:before:bg-gray-950/5 focus:outline-hidden dark:before:bg-gray-950/75 dark:hover:before:bg-white/5"
              data-close-site-nav
            >
              <CloseIcon class="text-gray-950 dark:text-white" />
            </button>
          </div>

          <div class="mt-4 flex flex-col gap-y-2">
            {links.map(({ href, label }) => (
              <a href={href} class={mobileLink}>{label}</a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Desktop nav -->
    <div class="flex items-center gap-x-6 text-sm/6 text-gray-950 max-lg:hidden dark:text-white">
      {links.map(({ href, label }) => (
        <a href={href}>{label}</a>
      ))}
      <button
        type="button"
        class="relative cursor-pointer *:relative before:absolute before:top-1/2 before:left-1/2 before:size-8 before:-translate-1/2 before:rounded-md hover:before:bg-gray-950/5 focus:outline-hidden dark:hover:before:bg-white/5"
        data-toggle-theme
        aria-label="Skift tema"
      >
        <SunIcon class="hidden text-gray-950 dark:block dark:text-white" />
        <MoonIcon class="block text-gray-950 dark:hidden dark:text-white" />
      </button>
    </div>
  </nav>
</div>

<script>
  const mobileNav = document.getElementById("site-mobile-nav");

  document.querySelectorAll("[data-open-site-nav]").forEach((btn) =>
    btn.addEventListener("click", () => mobileNav?.classList.remove("hidden"))
  );

  document.querySelectorAll("[data-close-site-nav]").forEach((btn) =>
    btn.addEventListener("click", () => mobileNav?.classList.add("hidden"))
  );

  document.querySelectorAll("[data-toggle-theme]").forEach((btn) =>
    btn.addEventListener("click", () => {
      const dark = !document.documentElement.classList.contains("dark");
      document.documentElement.classList.toggle("dark", dark);
      document.cookie = `theme=${dark ? "dark" : "light"};path=/;max-age=${60 * 60 * 24 * 365};SameSite=Lax`;
    })
  );
</script>
