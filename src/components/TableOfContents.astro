---
interface Props {
	contentId: string;
}

const { contentId } = Astro.props;
---

<nav id="table-of-contents" class="sticky top-20" data-toc-content={contentId}>
	<h2 class="text-sm/7 font-semibold text-gray-950 dark:text-white">On this page</h2>
	<ul class="mt-3 space-y-2 text-sm/7" data-toc-list></ul>
</nav>

<script>
	document.querySelectorAll("[data-toc-content]").forEach((nav) => {
		const contentId = nav.getAttribute("data-toc-content");
		if (!contentId) return;

		const content = document.getElementById(contentId);
		const list = nav.querySelector("[data-toc-list]");
		if (!content || !list) return;

		const headings = content.querySelectorAll("h2, h3");
		const items: { el: HTMLElement; link: HTMLAnchorElement }[] = [];

		headings.forEach((heading) => {
			if (!heading.id) {
				heading.id = heading.textContent?.toLowerCase().replace(/\s+/g, "-").replace(/[^\w-]/g, "") ?? "";
			}

			const li = document.createElement("li");
			const a = document.createElement("a");
			a.href = `#${heading.id}`;
			a.textContent = heading.textContent;
			a.className = "text-gray-500 hover:text-gray-700 dark:hover:text-gray-300";

			if (heading.tagName === "H3") {
				li.className = "pl-3";
			}

			li.appendChild(a);
			list.appendChild(li);
			items.push({ el: heading as HTMLElement, link: a });
		});

		if (items.length === 0) {
			(nav as HTMLElement).style.display = "none";
			return;
		}

		const observer = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						for (const item of items) {
							if (item.el === entry.target) {
								item.link.className = "font-medium text-gray-950 dark:text-white";
							} else {
								item.link.className = "text-gray-500 hover:text-gray-700 dark:hover:text-gray-300";
							}
						}
					}
				}
			},
			{ rootMargin: "-80px 0px -60% 0px" },
		);

		for (const item of items) {
			observer.observe(item.el);
		}
	});
</script>
