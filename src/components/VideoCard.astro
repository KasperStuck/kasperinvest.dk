---
import { Image } from "astro:assets";

interface Props {
	title: string;
	subtitle?: string;
	url: string;
	target?: string;
	thumbnailUrl: string;
	videoUrl?: string;
	youtubeId?: string;
	duration?: number;
	publishedAt?: string;
	viewCount?: number;
}

const { title, subtitle, url, target, thumbnailUrl, videoUrl, youtubeId, duration, publishedAt, viewCount } = Astro.props;

function formatDate(iso: string): string {
	const d = new Date(iso);
	const date = d.toLocaleDateString("da-DK", { day: "numeric", month: "short", year: "numeric" });
	const time = d.toLocaleTimeString("da-DK", { hour: "2-digit", minute: "2-digit" });
	return `${date} kl. ${time}`;
}

function formatDuration(seconds: number): string {
	const m = Math.floor(seconds / 60);
	const s = seconds % 60;
	return `${m}:${s.toString().padStart(2, "0")}`;
}

function formatViews(count: number): string {
	if (count >= 1_000_000) return `${(count / 1_000_000).toFixed(1).replace(/\.0$/, "")}M visninger`;
	if (count >= 1_000) return `${(count / 1_000).toFixed(1).replace(/\.0$/, "")}K visninger`;
	return `${count} visninger`;
}
---

<a href={url} target={target} rel={target === "_blank" ? "noopener noreferrer" : undefined} class="group block" data-video-card>
	<div class="relative overflow-hidden rounded-xl bg-gray-100 dark:bg-gray-800">
		<Image
			src={thumbnailUrl}
			alt={title}
			width={640}
			height={360}
			loading="lazy"
			class="aspect-video w-full object-cover transition-opacity group-hover:opacity-75"
		/>
		{videoUrl && (
			<video
				src={videoUrl}
				muted
				loop
				preload="none"
				class="absolute inset-0 hidden aspect-video w-full object-cover"
				data-hover-video
			/>
		)}
		{youtubeId && (
			<button
				type="button"
				data-play-youtube={youtubeId}
				class="absolute right-2 top-2 z-10 flex size-9 items-center justify-center rounded-full bg-gray-950/75 text-white opacity-0 transition-opacity group-hover:opacity-100 hover:bg-gray-950/90 cursor-pointer"
				aria-label="Afspil video"
			>
				<svg class="size-4 ml-0.5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
			</button>
		)}
		{subtitle && (
			<div class="absolute left-2 bottom-2 rounded bg-gray-950/75 px-1.5 py-0.5 text-xs/5 font-medium text-white">
				{subtitle}
			</div>
		)}
		{duration && (
			<div class="absolute right-2 bottom-2 rounded bg-gray-950/75 px-1.5 py-0.5 text-xs/5 font-medium text-white">
				{formatDuration(duration)}
			</div>
		)}
	</div>
	{(publishedAt || viewCount) && (
		<p class="mt-2 flex items-center justify-between text-sm/7 text-gray-500">
			{publishedAt && <span>{formatDate(publishedAt)}</span>}
			{viewCount != null && viewCount > 0 && <span>{formatViews(viewCount)}</span>}
		</p>
	)}
	<p class="mt-1 text-sm/7 font-semibold text-gray-950 dark:text-white">{title}</p>
</a>

<script>
	document.querySelectorAll("[data-video-card]").forEach((card) => {
		const video = card.querySelector<HTMLVideoElement>("[data-hover-video]");
		const img = card.querySelector("img");
		if (!video || !img) return;

		card.addEventListener("mouseenter", () => {
			video.classList.remove("hidden");
			video.play().catch(() => {});
		});

		card.addEventListener("mouseleave", () => {
			video.pause();
			video.currentTime = 0;
			video.classList.add("hidden");
		});
	});

	// Video modal (shared singleton)
	let modal: HTMLDivElement | null = document.querySelector("#video-modal");
	if (!modal) {
		modal = document.createElement("div");
		modal.id = "video-modal";
		modal.className = "fixed inset-0 z-50 hidden items-center justify-center bg-gray-950/80 backdrop-blur-sm";
		modal.innerHTML = `
			<div class="relative w-full max-w-4xl mx-4">
				<button type="button" id="video-modal-close" class="absolute -top-10 right-0 text-white hover:text-gray-300 cursor-pointer">
					<svg class="size-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
				</button>
				<div class="aspect-video w-full rounded-xl overflow-hidden bg-black">
					<iframe id="video-modal-iframe" class="w-full h-full" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
				</div>
			</div>
		`;
		document.body.appendChild(modal);

		const closeModal = () => {
			modal!.classList.add("hidden");
			modal!.classList.remove("flex");
			const iframe = document.getElementById("video-modal-iframe") as HTMLIFrameElement;
			iframe.src = "";
		};

		modal.querySelector("#video-modal-close")!.addEventListener("click", closeModal);
		modal.addEventListener("click", (e) => {
			if (e.target === modal) closeModal();
		});
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && !modal!.classList.contains("hidden")) closeModal();
		});
	}

	document.querySelectorAll<HTMLButtonElement>("[data-play-youtube]").forEach((btn) => {
		btn.addEventListener("click", (e) => {
			e.preventDefault();
			e.stopPropagation();
			const youtubeId = btn.dataset.playYoutube;
			const iframe = document.getElementById("video-modal-iframe") as HTMLIFrameElement;
			iframe.src = `https://www.youtube.com/embed/${youtubeId}?autoplay=1`;
			const m = document.getElementById("video-modal")!;
			m.classList.remove("hidden");
			m.classList.add("flex");
		});
	});
</script>
