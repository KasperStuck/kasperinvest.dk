---
interface Props {
	type?: astroHTML.JSX.HTMLInputTypeAttribute;
	id?: string;
	required?: boolean;
	class?: string;
	placeholder?: string;
	name?: string;
}

const { type = "text", id, required, class: className, placeholder, name, ...props } = Astro.props;
---

<input
	type={type}
	id={id}
	name={name}
	required={required}
	placeholder={placeholder}
	class:list={[className, "block w-full rounded-lg border border-gray-950/10 bg-transparent px-3 py-1.5 text-sm/7 text-gray-950 outline-none placeholder:text-gray-500 focus:border-gray-950/20 focus:ring-0 dark:border-white/10 dark:text-white dark:focus:border-white/20"]}
	{...props}
/>
