---
import ElectionLayout from "@/layouts/ElectionLayout.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import ChevronRightIcon from "@/icons/ChevronRightIcon.astro";
import { getElections, getElectionArticle, getElectionArticleContent } from "@/data/elections";

export function getStaticPaths() {
	return getElections().flatMap((election) =>
		election.articles.map((article) => ({
			params: { year: String(election.year), slug: article.id },
		})),
	);
}

const { year, slug } = Astro.params;
const article = getElectionArticle(Number(year), slug!);

if (!article) {
	return Astro.redirect("/404");
}

let Content: any = null;
try {
	Content = await getElectionArticleContent(Number(year), slug!);
} catch {
	// MDX file doesn't exist yet – will show "coming soon" fallback
}

const breadcrumbItems = [
	{ label: "KasperInvest", href: "/" },
	{ label: article.election.title, href: `/folketingsvalg/${year}`, class: "max-md:hidden" },
	{ label: article.title },
];
---

<ElectionLayout
	title={`${article.title} - ${article.election.title} - KasperInvest`}
	description={article.description}
	breadcrumbItems={breadcrumbItems}
	election={article.election}
>
	<div class="mx-auto max-w-7xl">
		<div class="mx-auto flex max-w-2xl gap-x-10 py-10 sm:py-14 lg:max-w-5xl">
			<div class="w-full flex-1">
				<div id="content" class="prose prose-sm dark:prose-invert">
					{Content ? <Content /> : (
						<div class="flex flex-col items-center justify-center py-20 text-center">
							<p class="text-lg font-medium text-gray-950 dark:text-white">Kommer snart</p>
							<p class="mt-2 text-sm text-gray-500">Denne artikel er under udarbejdelse.</p>
						</div>
					)}
				</div>
				<div class="mt-16 border-t border-gray-200 pt-8 dark:border-white/10">
					{article.next ? (
						<div class="flow-root">
							<a
								href={`/folketingsvalg/${year}/${article.next.id}`}
								class="-mx-3 -my-2 block rounded-xl px-3 py-2 hover:bg-gray-950/4 dark:hover:bg-white/5"
							>
								<p class="flex items-center gap-3 text-sm/7 text-gray-500">
									Næste parti
									<ChevronRightIcon />
								</p>
								<p class="mt-3 text-base/7 font-medium text-gray-950 dark:text-white">
									{article.next.title}
								</p>
								<p class="text-sm/7 text-gray-700 dark:text-gray-400">
									{article.next.description}
								</p>
							</a>
						</div>
					) : (
						<div class="flow-root">
							<a
								href="/"
								class="-mx-3 -my-2 block rounded-xl px-3 py-2 hover:bg-gray-950/4 dark:hover:bg-white/5"
							>
								<p class="flex items-center gap-3 text-sm/7 text-gray-500">
									Tilbage
									<ChevronRightIcon />
								</p>
								<p class="mt-3 text-base/7 font-medium text-gray-950 dark:text-white">
									Kursusoversigt
								</p>
								<p class="text-sm/7 text-gray-700 dark:text-gray-400">
									Gå tilbage til investeringskurset.
								</p>
							</a>
						</div>
					)}
				</div>
			</div>
			<div class="hidden w-66 lg:block">
				<TableOfContents contentId="content" />
			</div>
		</div>
	</div>
</ElectionLayout>
