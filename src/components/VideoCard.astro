---
import { Image } from "astro:assets";

interface Props {
	title: string;
	subtitle?: string;
	url: string;
	target?: string;
	thumbnailUrl: string;
	videoUrl?: string;
	youtubeId?: string;
	duration?: number;
	publishedAt?: string;
	viewCount?: number;
}

const {
	title,
	subtitle,
	url,
	target,
	thumbnailUrl,
	videoUrl,
	youtubeId,
	duration,
	publishedAt,
	viewCount,
} = Astro.props;

function formatDate(iso: string): string {
	const d = new Date(iso);
	const date = d.toLocaleDateString("da-DK", { day: "numeric", month: "short", year: "numeric" });
	const time = d.toLocaleTimeString("da-DK", { hour: "2-digit", minute: "2-digit" });
	return `${date} kl. ${time}`;
}

function formatDuration(seconds: number): string {
	const m = Math.floor(seconds / 60);
	const s = seconds % 60;
	return `${m}:${s.toString().padStart(2, "0")}`;
}

function formatViews(count: number): string {
	if (count >= 1_000_000) return `${(count / 1_000_000).toFixed(1).replace(/\.0$/, "")}M visninger`;
	if (count >= 1_000) return `${(count / 1_000).toFixed(1).replace(/\.0$/, "")}K visninger`;
	return `${count} visninger`;
}
---

<a href={url} target={target} rel={target === "_blank" ? "noopener noreferrer" : undefined} class="group block" data-video-card>
	<div class="relative overflow-hidden rounded-xl bg-gray-100 dark:bg-gray-800">
		<Image
			src={thumbnailUrl}
			alt={title}
			width={640}
			height={360}
			loading="lazy"
			class="aspect-video w-full object-cover transition-opacity group-hover:opacity-75"
		/>
		{videoUrl && (
			<video
				src={videoUrl}
				muted
				loop
				preload="none"
				class="absolute inset-0 hidden aspect-video w-full object-cover"
				data-hover-video
			/>
		)}
		{youtubeId && (
			<button
				type="button"
				data-play-youtube={youtubeId}
				class="absolute right-2 top-2 z-10 flex size-8 items-center justify-center rounded-full bg-white/90 text-gray-950 shadow-md ring-1 ring-gray-950/5 opacity-0 transition hover:bg-white group-hover:opacity-100 cursor-pointer dark:bg-gray-900/90 dark:text-white dark:ring-white/10 dark:hover:bg-gray-900"
				aria-label="Afspil video"
			>
				<svg viewBox="0 0 16 16" fill="currentColor" class="size-4"><path d="M3 3.732a1.5 1.5 0 0 1 2.305-1.265l6.706 4.267a1.5 1.5 0 0 1 0 2.531l-6.706 4.268A1.5 1.5 0 0 1 3 12.267V3.732Z" /></svg>
			</button>
		)}
		{subtitle && (
			<div class="absolute left-2 bottom-2 rounded bg-gray-950/75 px-1.5 py-0.5 text-xs/5 font-medium text-white">
				{subtitle}
			</div>
		)}
		{duration && (
			<div class="absolute right-2 bottom-2 rounded bg-gray-950/75 px-1.5 py-0.5 text-xs/5 font-medium text-white">
				{formatDuration(duration)}
			</div>
		)}
	</div>
	{(publishedAt || viewCount) && (
		<p class="mt-2 flex items-center justify-between text-sm/7 text-gray-600 dark:text-gray-400">
			{publishedAt && <span>{formatDate(publishedAt)}</span>}
			{viewCount != null && viewCount > 0 && <span>{formatViews(viewCount)}</span>}
		</p>
	)}
	<p class="mt-1 text-sm/7 font-semibold text-gray-950 dark:text-white">{title}</p>
</a>

<script>
	document.querySelectorAll("[data-video-card]").forEach((card) => {
		const video = card.querySelector<HTMLVideoElement>("[data-hover-video]");
		const img = card.querySelector("img");
		if (!video || !img) return;

		card.addEventListener("mouseenter", () => {
			video.classList.remove("hidden");
			video.play().catch(() => {});
		});

		card.addEventListener("mouseleave", () => {
			video.pause();
			video.currentTime = 0;
			video.classList.add("hidden");
		});
	});

	// Video modal (shared singleton)
	let modal: HTMLDivElement | null = document.querySelector("#video-modal");
	if (!modal) {
		modal = document.createElement("div");
		modal.id = "video-modal";
		modal.className = "fixed inset-0 z-50 hidden items-center justify-center bg-gray-950/60 backdrop-blur-sm";
		modal.innerHTML = `
			<div class="relative w-full max-w-4xl mx-4">
				<button type="button" id="video-modal-close" class="absolute -right-2 -top-10 flex size-8 items-center justify-center rounded-full bg-white/90 text-gray-950 shadow-md ring-1 ring-gray-950/5 transition hover:bg-white cursor-pointer dark:bg-gray-900/90 dark:text-white dark:ring-white/10 dark:hover:bg-gray-900">
					<svg viewBox="0 0 16 16" fill="currentColor" class="size-4"><path d="M5.28 4.22a.75.75 0 0 0-1.06 1.06L6.94 8l-2.72 2.72a.75.75 0 1 0 1.06 1.06L8 9.06l2.72 2.72a.75.75 0 1 0 1.06-1.06L9.06 8l2.72-2.72a.75.75 0 0 0-1.06-1.06L8 6.94 5.28 4.22Z" /></svg>
				</button>
				<div class="aspect-video w-full overflow-hidden rounded-xl bg-gray-100 shadow-lg ring-1 ring-gray-950/5 dark:bg-gray-800 dark:ring-white/10 dark:shadow-gray-950/50">
					<iframe id="video-modal-iframe" class="w-full h-full" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
				</div>
			</div>
		`;
		document.body.appendChild(modal);

		const closeModal = () => {
			modal!.classList.add("hidden");
			modal!.classList.remove("flex");
			const iframe = document.getElementById("video-modal-iframe") as HTMLIFrameElement;
			iframe.src = "";
		};

		modal.querySelector("#video-modal-close")!.addEventListener("click", closeModal);
		modal.addEventListener("click", (e) => {
			if (e.target === modal) closeModal();
		});
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && !modal!.classList.contains("hidden")) closeModal();
		});
	}

	document.querySelectorAll<HTMLButtonElement>("[data-play-youtube]").forEach((btn) => {
		btn.addEventListener("click", (e) => {
			e.preventDefault();
			e.stopPropagation();
			const youtubeId = btn.dataset.playYoutube;
			const iframe = document.getElementById("video-modal-iframe") as HTMLIFrameElement;
			iframe.src = `https://www.youtube.com/embed/${youtubeId}?autoplay=1`;
			const m = document.getElementById("video-modal")!;
			m.classList.remove("hidden");
			m.classList.add("flex");
		});
	});
</script>
