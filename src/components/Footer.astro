---
import Logo from "@/components/Logo.astro";
import { getGlossaryTerms } from "@/data/glossary";
import { getModules } from "@/data/lessons";
import { getPensionTypes } from "@/data/pension";
import { getPlatforms } from "@/data/platforms";
import { getSavingsCategories } from "@/data/savings";
import { api, convex } from "@/lib/convex";

const modules = getModules();
const pensionTypes = getPensionTypes();
const platforms = getPlatforms();
const glossaryTerms = getGlossaryTerms().slice(0, 5);
const savingsCategories = await getSavingsCategories();

const CACHE_TTL = 60 * 60 * 1000; // 1 time

import type { FunctionReturnType } from "convex/server";

type FooterVideo = FunctionReturnType<typeof api.videos.listRecent>[number];
type FooterChannel = FunctionReturnType<typeof api.channels.list>[number];
let _footerCache: {
	videos: FooterVideo[];
	channelMap: Map<string, FooterChannel>;
	ts: number;
} | null = null;

async function getFooterVideos() {
	if (_footerCache && Date.now() - _footerCache.ts < CACHE_TTL) return _footerCache;
	const [videos, channels] = await Promise.all([
		convex.query(api.videos.listRecent, { limit: 5 }),
		convex.query(api.channels.list, {}),
	]);
	_footerCache = {
		videos,
		channelMap: new Map(channels.map((ch) => [ch.channelId, ch])),
		ts: Date.now(),
	};
	return _footerCache;
}

const { videos: recentVideos, channelMap } = await getFooterVideos();

function videoUrl(v: { slug?: string; videoId: string; channelId: string }) {
	const ch = channelMap.get(v.channelId);
	const handle = ch?.customUrl?.replace(/^@/, "") ?? v.channelId;
	return `/youtube/${handle}/${v.slug ?? v.videoId}`;
}
---

<footer class="border-t border-gray-950/10 dark:border-white/10">
	<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:py-16">
		<div class="mb-10">
			<a href="/">
				<Logo class="text-lg text-gray-950 dark:text-white" />
			</a>
			<p class="mt-3 max-w-md text-sm/6 text-gray-600 dark:text-gray-400">
				KasperInvest hjælper dig med at lære at investere gennem gratis kurser, guides og værktøjer. Uanset om du er helt ny eller vil udvide din viden om aktier, ETF'er og pension, finder du alt hvad du skal bruge for at komme i gang.
			</p>
		</div>
		<div class="grid grid-cols-2 gap-8 md:grid-cols-4">
			<!-- Kursus -->
			<div>
				<h3 class="text-sm/6 font-semibold text-gray-950 dark:text-white"><a href="/">Kursus</a></h3>
				<ul class="mt-3 space-y-2">
					{modules.map((mod, i) => (
						<li>
							<a href={`/${mod.lessons[0].id}`} class="text-sm/6 text-gray-600 hover:text-gray-950 dark:text-gray-400 dark:hover:text-white">
								Del {i + 1}: {mod.title}
							</a>
						</li>
					))}
					<li>
						<a href="/" class="text-sm/6 font-medium text-gray-950 hover:text-gray-700 dark:text-white dark:hover:text-gray-300">
							Se alle lektioner &rarr;
						</a>
					</li>
				</ul>
			</div>

			<!-- Pension + Platforme -->
			<div>
				<h3 class="text-sm/6 font-semibold text-gray-950 dark:text-white"><a href="/pension">Pension</a></h3>
				<ul class="mt-3 space-y-2">
					{pensionTypes.map((p) => (
						<li>
							<a href={`/pension/${p.id}`} class="text-sm/6 text-gray-600 hover:text-gray-950 dark:text-gray-400 dark:hover:text-white">
								{p.title}
							</a>
						</li>
					))}
				</ul>

				<h3 class="mt-8 text-sm/6 font-semibold text-gray-950 dark:text-white"><a href="/platforme">Platforme</a></h3>
				<ul class="mt-3 space-y-2">
					{platforms.map((p) => (
						<li>
							<a href={`/platforme/${p.id}`} class="text-sm/6 text-gray-600 hover:text-gray-950 dark:text-gray-400 dark:hover:text-white">
								{p.title}
							</a>
						</li>
					))}
				</ul>
			</div>

			<!-- Ordbog + YouTube -->
			<div>
				<h3 class="text-sm/6 font-semibold text-gray-950 dark:text-white"><a href="/ordbog">Ordbog</a></h3>
				<ul class="mt-3 space-y-2">
					{glossaryTerms.map((t) => (
						<li>
							<a href={`/ordbog/${t.id}`} class="text-sm/6 text-gray-600 hover:text-gray-950 dark:text-gray-400 dark:hover:text-white">
								{t.title}
							</a>
						</li>
					))}
					<li>
						<a href="/ordbog" class="text-sm/6 font-medium text-gray-950 hover:text-gray-700 dark:text-white dark:hover:text-gray-300">
							Se alle &rarr;
						</a>
					</li>
				</ul>

				<h3 class="mt-8 text-sm/6 font-semibold text-gray-950 dark:text-white"><a href="/youtube">YouTube</a></h3>
				<ul class="mt-3 space-y-2">
					{recentVideos.map((v) => (
						<li>
							<a href={videoUrl(v)} class="text-sm/6 text-gray-600 hover:text-gray-950 dark:text-gray-400 dark:hover:text-white line-clamp-1">
								{v.title}
							</a>
						</li>
					))}
					<li>
						<a href="/youtube" class="text-sm/6 font-medium text-gray-950 hover:text-gray-700 dark:text-white dark:hover:text-gray-300">
							Se alle videoer &rarr;
						</a>
					</li>
				</ul>
			</div>

			<!-- Mere -->
			<div>
				<h3 class="text-sm/6 font-semibold text-gray-950 dark:text-white"><a href="/spar-penge">Spar penge</a></h3>
				<ul class="mt-3 space-y-2">
					{savingsCategories.map((cat) => (
						<li>
							<a href={`/spar-penge/${cat.id}`} class="text-sm/6 text-gray-600 hover:text-gray-950 dark:text-gray-400 dark:hover:text-white">
								{cat.title}
							</a>
						</li>
					))}
				</ul>

				<h3 class="mt-8 text-sm/6 font-semibold text-gray-950 dark:text-white">Mere</h3>
				<ul class="mt-3 space-y-2">
					<li>
						<a href="/resources" class="text-sm/6 text-gray-600 hover:text-gray-950 dark:text-gray-400 dark:hover:text-white">
							Ressourcer
						</a>
					</li>
					<li>
						<a href="/folketingsvalg" class="text-sm/6 text-gray-600 hover:text-gray-950 dark:text-gray-400 dark:hover:text-white">
							Folketingsvalg
						</a>
					</li>
					<li>
						<a href="/sitemap" class="text-sm/6 text-gray-600 hover:text-gray-950 dark:text-gray-400 dark:hover:text-white">
							Sitemap
						</a>
					</li>
				</ul>
			</div>
		</div>

		<div class="mt-12 border-t border-gray-950/10 pt-8 dark:border-white/10">
			<p class="text-sm/6 text-gray-600 dark:text-gray-500">
				&copy; {new Date().getFullYear()} KasperInvest. Indholdet er kun til uddannelsesformål og udgør ikke finansiel rådgivning.
			</p>
		</div>
	</div>
</footer>
